# Gmail SMTP
# Copy this file to backend/.env and replace the placeholders locally.
# Never commit backend/.env or paste the app password into tickets or chat.
SPRING_MAIL_USERNAME=your-gmail-address@example.com
SPRING_MAIL_PASSWORD=your-16-character-google-app-password
PROJECT_MAIL_FROM_ADDRESS=your-gmail-address@example.com
PROJECT_MAIL_FROM_NAME=ProjectAdmin

# Runtime secrets
OPENAI_API_KEY=your-openai-api-key
JWT_SECRET=replace-with-a-long-random-secret
KEYSTORE_PASSWORD=replace-when-digital-signing-is-enabled

# Relational database
# AWS runtime values are generated from Secrets Manager. Do not commit real values.
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ADMIN?useSSL=false&serverTimezone=Asia/Tokyo&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_BATCH_JDBC_INITIALIZE_SCHEMA=always
SPRING_FLYWAY_ENABLED=false

# MongoDB / Redis
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/admin
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Container runtime paths
PROJECT_STORAGE_LOCAL_BASE_PATH=/app/storage
PROJECT_IMPORTS_SCRIPT_PYTHON_COMMAND=/opt/projectadmin-python/bin/python
