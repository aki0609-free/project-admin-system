document_bucket_name   = "replace-with-a-globally-unique-document-bucket"
cloudflare_account_id  = "replace-with-cloudflare-account-id"
cloudflare_zone_id     = "replace-with-cloudflare-zone-id"
cloudflare_zone_name   = "example.com"
cloudflare_tunnel_name = "project-admin-dev-ec2"
github_repository      = "your-github-owner/project-admin-system"

# Keep real email addresses out of committed tfvars files.
cloudflare_allowed_emails = [
  "authorized-user@example.com",
]
